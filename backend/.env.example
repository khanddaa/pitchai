GROQ_API_KEY=your_groq_api_key_here

# PostgreSQL холболтын мөр
# Render.com-д автоматаар тавигдана (render.yaml-аас)
# Локал: postgresql://postgres:postgres@localhost:5432/pitchai
DATABASE_URL=postgresql://user:password@localhost:5432/pitchai

# Зөвшөөрөгдсөн frontend origin-ууд (таслалаар тусгаарлана)
# Development-д тохируулаагүй бол http://localhost:5173 ашиглана
ALLOWED_ORIGINS=https://pitchai.mn,https://www.pitchai.mn
